# ── Stage 1: Builder ──────────────────────────────────────────
# Install heavy dependencies in a separate stage to keep final image cleaner
FROM python:3.11-slim AS builder

WORKDIR /app

# System dependencies needed for Whisper, Coqui, and audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    espeak-ng \
    libsndfile1 \
    libgomp1 \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt


# ── Stage 2: Runtime ──────────────────────────────────────────
FROM python:3.11-slim AS runtime

WORKDIR /app

# Only copy runtime system libs (not build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    espeak-ng \
    libsndfile1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed Python packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy backend source code
COPY backend/ ./backend/

# Create cache directories for model weights
# These will be mounted as Docker volumes so models persist across restarts
RUN mkdir -p /root/.cache/whisper /root/.local/share/tts

# Expose FastAPI port
EXPOSE 8000

# PYTHONPATH ensures 'from config import ...' works inside backend/
ENV PYTHONPATH=/app/backend

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]